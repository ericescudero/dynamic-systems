{UTF-8}
Lista_de_Espera= INTEG (Ingreso_Lista-Egreso_Atencion-Egresos_Administrativos,
		2100000)
	~	pacientes
	~	NIVEL. Cantidad de pacientes enumerados en la lista de espera del sector pГғВҜГӮВҝГӮВҪblico, \
		desde el mГғВҜГӮВҝГӮВҪs antiguo al mГғВҜГӮВҝГӮВҪs reciente. Fuente: DEIS/MINSAL Lista Espera No \
		GES 2023. https://deis.minsal.cl/estadisticas-de-salud/	|

Ingreso_Lista=Demanda_Sector_Publico
	~	pacientes/Dia
	~	FLUJO DE ENTRADA. Pacientes que ingresan a la lista de espera por dГғВҜГӮВҝГӮВҪa, \
		equivalente a la demanda del sector pГғВҜГӮВҝГӮВҪblico. Variable endГғВҜГӮВҝГӮВҪgena.	|

Egreso_Atencion=Pacientes_Atendidos_x_Dia
	~	pacientes/Dia
	~	FLUJO DE SALIDA. Pacientes que salen de la lista por ser atendidos por un \
		especialista en el sector pГғВҜГӮВҝГӮВҪblico. Variable endГғВҜГӮВҝГӮВҪgena.	|

Egresos_Administrativos=Lista_de_Espera*Tasa_Egresos_Administrativos
	~	pacientes/Dia
	~	FLUJO DE SALIDA. Pacientes que salen de la lista por razones administrativas \
		(desistimiento, duplicados, fallecidos, cambio de previsГғВҜГӮВҝГӮВҪn). Proporcional al \
		tamaГғВҜГӮВҝГӮВҪo de la lista. Variable endГғВҜГӮВҝГӮВҪgena. Fuente: DEIS/MINSAL \
		(estimado ~3.65% anual).	|

Tiempo_de_Espera=Lista_de_Espera/MAX(Egreso_Atencion+Egresos_Administrativos,1)
	~	Dia
	~	AUXILIAR. Tiempo promedio que un paciente permanece en la lista de espera. \
		Calculado mediante la Ley de Little: L = lambda * W => W = L / lambda. \
		Variable endГғВҜГӮВҝГӮВҪgena. Fuente: Ley de Little (1961).	|

Pacientes_Atendidos_x_Dia=Horas_Especialistas_Sector_Publico*Productividad_Especialista
	~	pacientes/Dia
	~	AUXILIAR. Cantidad de pacientes de lista de espera atendidos por dГғВҜГӮВҝГӮВҪa en el \
		sector pГғВҜГӮВҝГӮВҪblico. Variable endГғВҜГӮВҝГӮВҪgena. Fuente: MINSAL Normas TГғВҜГӮВҝГӮВҪcnicas.	|

Fraccion_Privado=MIN(0.95,MAX(0.05,Fraccion_Privado_Base+Sensibilidad_Privada*(Tiempo_de_Espera-Tiempo_Espera_Referencia)))
	~	adimensional
	~	AUXILIAR. FracciГғВҜГӮВҝГӮВҪn de la demanda total que se deriva al sector privado, \
		funcional del tiempo de espera. A mayor espera, mГғВҜГӮВҝГӮВҪs pacientes optan por lo \
		privado. Acotada en [0.05, 0.95]. Variable endГғВҜГӮВҝГӮВҪgena.	|

Demanda_Sector_Privado=Demanda_Total*Fraccion_Privado
	~	pacientes/Dia
	~	AUXILIAR. Cantidad de pacientes que buscan atenciГғВҜГӮВҝГӮВҪn en el sector privado por \
		dГғВҜГӮВҝГӮВҪa. Variable endГғВҜГӮВҝГӮВҪgena. Fuente: SIS/FONASA EstadГғВҜГӮВҝГӮВҪsticas 2023. \
		https://www.supersalud.gob.cl/estadisticas	|

Demanda_Sector_Publico=MAX(Demanda_Total-Demanda_Sector_Privado,0)
	~	pacientes/Dia
	~	AUXILIAR. Cantidad de pacientes que buscan atenciГғВҜГӮВҝГӮВҪn en el sector pГғВҜГӮВҝГӮВҪblico \
		por dГғВҜГӮВҝГӮВҪa (ingresan a la lista). Variable endГғВҜГӮВҝГӮВҪgena.	|

Demanda_Total=4000
	~	pacientes/Dia
	~	PARГҒMETRO. Demanda total diaria de atenciГғВҜГӮВҝГӮВҪn especialista (pГғВҜГӮВҝГӮВҪblico + privado). \
		Variable exГғВҜГӮВҝГӮВҪgena. Fuente: MINSAL Plan ReducciГғВҜГӮВҝГӮВҪn Lista de Espera 2023. \
		https://www.minsal.cl/lista-de-espera/	|

Horas_Especialistas_Sector_Publico=1000
	~	horas/Dia
	~	PARГҒMETRO. Horas totales de especialista dedicadas a lista de espera en sector \
		pГғВҜГӮВҝГӮВҪblico por dГғВҜГӮВҝГӮВҪa. Variable exГғВҜГӮВҝГӮВҪgena. Fuente: DEIS REM (Resumen \
		EstadГғВҜГӮВҝГӮВҪstico Mensual). https://deis.minsal.cl/rem/	|

Productividad_Especialista=2.5
	~	pacientes/horas
	~	PARГҒMETRO. NГғВҜГӮВҝГӮВҪmero de pacientes de lista de espera atendidos por hora de \
		especialista. Variable exГғВҜГӮВҝГӮВҪgena. Fuente: MINSAL Normas TГғВҜГӮВҝГӮВҪcnicas de \
		AtenciГғВҜГӮВҝГӮВҪn.	|

Tasa_Egresos_Administrativos=1e-04
	~	1/Dia
	~	PARГҒMETRO. FracciГғВҜГӮВҝГӮВҪn de la lista que egresa por razones administrativas por \
		dГғВҜГӮВҝГӮВҪa (equivale a ~3.65% anual). Variable exГғВҜГӮВҝГӮВҪgena. Fuente: DEIS/MINSAL \
		(estimado). https://deis.minsal.cl/estadisticas-de-salud/	|

Fraccion_Privado_Base=0.3
	~	adimensional
	~	PARГҒMETRO. FracciГғВҜГӮВҝГӮВҪn base de la demanda que se atiende en el sector privado \
		cuando el tiempo de espera es igual al de referencia. Variable exГғВҜГӮВҝГӮВҪgena. \
		Fuente: SIS/FONASA EstadГғВҜГӮВҝГӮВҪsticas 2023. \
		https://www.fonasa.cl/sites/fonasa/transparencia/estadisticas	|

Tiempo_Espera_Referencia=840
	~	Dia
	~	PARГҒMETRO. Tiempo de espera de referencia (dГӯas) al cual corresponde la fracciГғВҜГӮВҝГӮВҪn \
		privado base. Variable exГғВҜГӮВҝГӮВҪgena. Fuente: DEIS Lista de Espera promedio \
		ponderado 2023. https://deis.minsal.cl/estadisticas-de-salud/	|

Sensibilidad_Privada=0.00025
	~	1/Dia
	~	PARГҒMETRO. Incremento en la fracciГғВҜГӮВҝГӮВҪn privada por cada dГғВҜГӮВҝГӮВҪa adicional de \
		espera respecto al tiempo de referencia. Calibrado para reproducir \
		comportamiento histГғВҜГӮВҝГӮВҪrico 2014-2023. Variable exГғВҜГӮВҝГӮВҪgena.	|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 3650
	~	Dia
	~	The final time for the simulation (10 years).
	|

INITIAL TIME  = 0
	~	Dia
	~	The initial time for the simulation.
	|

SAVEPER  =
        TIME STEP
	~	Dia [0,?]
	~	The frequency with which output is stored.
	|

METHOD  = RK4
	~
	~	The numerical integration method (Runge-Kutta order 4).
	|

TIME STEP  = 1
	~	Dia [0,?]
	~	The time step for the simulation (1 day).
	|

